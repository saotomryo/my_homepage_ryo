---
import '../styles/global.css';

interface Props {
  locale: 'ja' | 'en';
  title: string;
  description: string;
  path: string;
}

const { locale, title, description, path } = Astro.props;

const navText = {
  ja: {
    home: 'トップ',
    about: '自己紹介',
    links: 'リンク集',
    activities: '活動まとめ',
    kuroneko: '黒猫の大冒険',
    marketBrief: '日本市場概説',
    lang: 'Language'
  },
  en: {
    home: 'Home',
    about: 'About',
    links: 'Links',
    activities: 'Activities',
    kuroneko: 'Black Cat Adventure',
    marketBrief: 'Japan Market Brief',
    lang: '言語'
  }
};

const t = navText[locale];
const oppositeLocale = locale === 'ja' ? 'en' : 'ja';
const switchedPath = path.replace(/^\/(ja|en)/, `/${oppositeLocale}`);
const basePath = Astro.site ? new URL(Astro.site).pathname.replace(/\/$/, '') : '';

function withBase(inputPath: string) {
  if (!inputPath.startsWith('/')) return inputPath;
  return `${basePath}${inputPath}`;
}
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <script is:inline>
      (() => {
        const measurementId = 'G-BCBQR9FHCM';
        const loadGtag = () => {
          if (window.__gaLoaded) return;
          window.__gaLoaded = true;
          window.dataLayer = window.dataLayer || [];
          window.gtag = window.gtag || function gtag() {
            window.dataLayer.push(arguments);
          };
          const script = document.createElement('script');
          script.async = true;
          script.src = `https://www.googletagmanager.com/gtag/js?id=${measurementId}`;
          script.onload = () => {
            window.gtag('js', new Date());
            window.gtag('config', measurementId);
          };
          document.head.appendChild(script);
        };

        if ('requestIdleCallback' in window) {
          window.requestIdleCallback(loadGtag, { timeout: 2500 });
        } else {
          window.addEventListener('load', () => {
            window.setTimeout(loadGtag, 1200);
          }, { once: true });
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="logo" href={withBase(`/${locale}`)}>Ryo Saotome</a>
      <nav>
        <a href={withBase(`/${locale}`)}>{t.home}</a>
        <a href={withBase(`/${locale}/about`)}>{t.about}</a>
        <a href={withBase(`/${locale}/links`)}>{t.links}</a>
        <a href={withBase(`/${locale}/activities`)}>{t.activities}</a>
        <a href={withBase(`/${locale}/kuroneko`)}>{t.kuroneko}</a>
        <a href={withBase(`/${locale}/market-brief`)}>{t.marketBrief}</a>
      </nav>
      <a class="lang" href={withBase(switchedPath)}>{t.lang}: {oppositeLocale.toUpperCase()}</a>
    </header>
    <main class="container">
      <slot />
    </main>
  </body>
</html>
