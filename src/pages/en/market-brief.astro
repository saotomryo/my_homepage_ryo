---
import BaseLayout from '../../layouts/BaseLayout.astro';

const embedUrl = 'https://www.youtube-nocookie.com/embed/videoseries?si=GVtefYQlLh8MS2V-&list=PLiKMZcPo7vB_3B_tG90ddVZFzitwQ_3lF';
const playlistUrl = 'https://www.youtube.com/playlist?list=PLiKMZcPo7vB_3B_tG90ddVZFzitwQ_3lF';
---

<BaseLayout
  locale="en"
  title="Japan Market Brief"
  description="Play the Japan Market Brief podcast playlist on this page."
  path="/en/market-brief"
>
  <section class="page-head">
    <h1>Japan Market Brief</h1>
    <p>Play the Japan Market Brief playlist directly on this page.</p>
  </section>

  <section class="list-block">
    <div class="video-frame-wrap">
      <iframe
        class="video-frame"
        src={embedUrl}
        title="Japan Market Brief YouTube player"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
    <p class="video-meta">
      <a href={playlistUrl} target="_blank" rel="noreferrer">Open playlist on YouTube</a>
    </p>
  </section>
</BaseLayout>
