---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LinkList from '../../components/LinkList.astro';
import profile from '../../content/generated/ja/profile.json';
---

<BaseLayout
  locale="ja"
  title="リンク集"
  description="SNS、技術発信、仕事の相談先などのリンクをまとめています。"
  path="/ja/links"
>
  <section class="page-head">
    <h1>リンク集</h1>
    <p>発信活動と受託窓口の一覧です。</p>
  </section>

  <LinkList items={[...profile.links, ...profile.work_contacts]} />
</BaseLayout>
