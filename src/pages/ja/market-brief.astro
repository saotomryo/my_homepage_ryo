---
import BaseLayout from '../../layouts/BaseLayout.astro';

const embedUrl = 'https://www.youtube-nocookie.com/embed/videoseries?si=4ip7D_N6abEgzm8v&list=PLiKMZcPo7vB9fN9Ev4J-3QzbJsXI9haVM';
const playlistUrl = 'https://www.youtube.com/playlist?list=PLiKMZcPo7vB9fN9Ev4J-3QzbJsXI9haVM';
---

<BaseLayout
  locale="ja"
  title="日本市場概説"
  description="日本市場概説のポッドキャストをこのページで連続再生できます。"
  path="/ja/market-brief"
>
  <section class="page-head">
    <h1>日本市場概説</h1>
    <p>日本市場概説のプレイリストをこのページで続けて再生できます。</p>
  </section>

  <section class="list-block">
    <div class="video-frame-wrap">
      <iframe
        class="video-frame"
        src={embedUrl}
        title="日本市場概説 YouTube player"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        referrerpolicy="strict-origin-when-cross-origin"
        allowfullscreen
      ></iframe>
    </div>
    <p class="video-meta">
      <a href={playlistUrl} target="_blank" rel="noreferrer">YouTubeでプレイリストを開く</a>
    </p>
  </section>
</BaseLayout>
